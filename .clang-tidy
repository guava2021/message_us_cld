---
# clang-tidy configuration — C++ Core Guidelines for HFT C++17
#
# Disabled checks and rationale:
#   cppcoreguidelines-avoid-magic-numbers   — HFT constants (kCacheLine, kMagic, etc.) are intentional
#   cppcoreguidelines-pro-type-reinterpret-cast — required for shm slot pointer arithmetic
#   cppcoreguidelines-pro-bounds-pointer-arithmetic — required for slot_ptr()
#   cppcoreguidelines-pro-bounds-array-to-pointer-decay — used in memcpy / C interop
#   cppcoreguidelines-avoid-c-arrays        — cache-aligned padding arrays are intentional
#   modernize-use-trailing-return-type      — style preference, not enforced
#   readability-magic-numbers               — same as avoid-magic-numbers
#   readability-identifier-length           — short names (_pad, cb, sz) are idiomatic here
#   bugprone-easily-swappable-parameters    — too noisy for low-level APIs

Checks: >
  -*,
  #  clang-diagnostic-*,
  #  cppcoreguidelines-*,
  #  modernize-*,
  #  readability-*,
  performance-*,
  bugprone-*,

  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-using,

  cppcoreguidelines-pro-type-member-init,
  cppcoreguidelines-slicing,

  # -cppcoreguidelines-pro-type-reinterpret-cast,
  # -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  # -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  # -cppcoreguidelines-avoid-c-arrays,
  # -cppcoreguidelines-pro-type-vararg,
  
  # -cppcoreguidelines-no-malloc,
  # -cppcoreguidelines-owning-memory,

WarningsAsErrors: >
  cppcoreguidelines-pro-type-member-init,
  cppcoreguidelines-slicing,
  performance-move-const-arg,
  bugprone-use-after-move,
  bugprone-dangling-handle,

HeaderFilterRegex: "spsc_bus\\.hpp"

CheckOptions:
  - key:   readability-braces-around-statements.ShortStatementLines
    value: "2"
  - key:   cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: "true"
